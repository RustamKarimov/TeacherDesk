DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
TEACHERDESK_LIBRARY_ROOT=../local_library

# Default local SQLite database.
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Optional PostgreSQL settings for later. Set DB_ENGINE=django.db.backends.postgresql to use these.
POSTGRES_DB=teacherdesk
POSTGRES_USER=teacherdesk
POSTGRES_PASSWORD=teacherdesk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
